# Part 2 Dataset Agent – copy to .env.local and fill in

# Required: Nemotron (NVIDIA NIM). Get key at https://build.nvidia.com (view code for model)
NVIDIA_API_KEY=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
# or
NIM_API_KEY=

# Kaggle (for dataset search). Create token at https://www.kaggle.com/settings -> Create API Token
KAGGLE_USERNAME=
KAGGLE_KEY=

# Optional: Google Dataset Search via Custom Search JSON API
# Create API key: https://console.cloud.google.com/apis/credentials
# Create CSE that includes datasetsearch.research.google.com: https://programmablesearchengine.google.com/
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
